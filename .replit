run = "python3 -m streamlit run unrealai/dashboard.py --server.address 0.0.0.0 --server.port 3000 --server.headless true"

[deployment]
build = "python3 -m pip install -r requirements.viewer.txt"
run = ["sh", "-c", "python3 -m streamlit run unrealai/dashboard.py --server.address 0.0.0.0 --server.port 3000 --server.headless true"]
